<?xml version="1.0"?>
<robot name="multi_sensor_bot" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- ===== Parameters ===== -->
  <xacro:property name="base_radius" value="0.18"/>
  <xacro:property name="base_height" value="0.10"/>
  <xacro:property name="wheel_radius" value="0.033"/>
  <xacro:property name="wheel_width"  value="0.018"/>
  <xacro:property name="wheel_sep"    value="0.287"/>
  <xacro:property name="base_mass"    value="2.0"/>

  <!-- ===== Materials ===== -->
  <material name="grey"><color rgba="0.4 0.4 0.4 1"/></material>
  <material name="dark"><color rgba="0.1 0.1 0.1 1"/></material>
  <material name="blue"><color rgba="0.1 0.3 0.9 1"/></material>
  <material name="red"><color rgba="0.9 0.1 0.1 1"/></material>

  <!-- ===== Inertial macros ===== -->
  <xacro:macro name="cyl_inertial" params="m r h">
    <inertial>
      <mass value="${m}"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="${(1/12)*m*(3*r*r + h*h)}" iyy="${(1/12)*m*(3*r*r + h*h)}" izz="${0.5*m*r*r}"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </xacro:macro>
  <xacro:macro name="box_inertial" params="m x y z">
    <inertial>
      <mass value="${m}"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="${(1/12)*m*(y*y+z*z)}" iyy="${(1/12)*m*(x*x+z*z)}" izz="${(1/12)*m*(x*x+y*y)}"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </xacro:macro>

  <!-- ===== Base footprint / link ===== -->
  <link name="base_footprint"/>

  <joint name="base_joint" type="fixed">
    <parent link="base_footprint"/>
    <child  link="base_link"/>
    <origin xyz="0 0 ${wheel_radius}" rpy="0 0 0"/>
  </joint>

  <link name="base_link">
    <visual>
      <origin xyz="0 0 ${base_height/2}" rpy="0 0 0"/>
      <geometry><cylinder radius="${base_radius}" length="${base_height}"/></geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <origin xyz="0 0 ${base_height/2}" rpy="0 0 0"/>
      <geometry><cylinder radius="${base_radius}" length="${base_height}"/></geometry>
    </collision>
    <xacro:cyl_inertial m="${base_mass}" r="${base_radius}" h="${base_height}"/>
  </link>

  <!-- ===== Wheels ===== -->
  <xacro:macro name="wheel" params="prefix y_offset">
    <link name="${prefix}_wheel_link">
      <visual>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
        <geometry><cylinder radius="${wheel_radius}" length="${wheel_width}"/></geometry>
        <material name="dark"/>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
        <geometry><cylinder radius="${wheel_radius}" length="${wheel_width}"/></geometry>
      </collision>
      <xacro:cyl_inertial m="0.1" r="${wheel_radius}" h="${wheel_width}"/>
    </link>
    <joint name="${prefix}_wheel_joint" type="continuous">
      <parent link="base_link"/>
      <child  link="${prefix}_wheel_link"/>
      <origin xyz="0 ${y_offset} 0" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
    </joint>
    <gazebo reference="${prefix}_wheel_link">
      <mu1>1.0</mu1><mu2>1.0</mu2>
    </gazebo>
  </xacro:macro>
  <xacro:wheel prefix="left"  y_offset="${ wheel_sep/2}"/>
  <xacro:wheel prefix="right" y_offset="${-wheel_sep/2}"/>

  <!-- ===== Caster ===== -->
  <link name="caster_link">
    <visual><geometry><sphere radius="0.015"/></geometry><material name="dark"/></visual>
    <collision><geometry><sphere radius="0.015"/></geometry></collision>
    <inertial><mass value="0.01"/><inertia ixx="1e-6" iyy="1e-6" izz="1e-6" ixy="0" ixz="0" iyz="0"/></inertial>
  </link>
  <joint name="caster_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="caster_link"/>
    <origin xyz="-0.12 0 ${-wheel_radius+0.015}" rpy="0 0 0"/>
  </joint>
  <gazebo reference="caster_link">
    <mu1>0.0</mu1><mu2>0.0</mu2>
  </gazebo>

  <!-- ===== LIDAR ===== -->
  <link name="lidar_link">
    <visual><geometry><cylinder radius="0.04" length="0.04"/></geometry><material name="red"/></visual>
    <collision><geometry><cylinder radius="0.04" length="0.04"/></geometry></collision>
    <xacro:cyl_inertial m="0.1" r="0.04" h="0.04"/>
  </link>
  <joint name="lidar_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="lidar_link"/>
    <origin xyz="0 0 ${base_height + 0.04}" rpy="0 0 0"/>
  </joint>
  <gazebo reference="lidar_link">
    <sensor name="lidar_sensor" type="ray">
      <pose>0 0 0 0 0 0</pose>
      <update_rate>10</update_rate>
      <visualize>true</visualize>
      <ray>
        <scan><horizontal>
          <samples>360</samples><resolution>1</resolution>
          <min_angle>-3.14159</min_angle><max_angle>3.14159</max_angle>
        </horizontal></scan>
        <range><min>0.12</min><max>12.0</max><resolution>0.01</resolution></range>
        <noise><type>gaussian</type><mean>0</mean><stddev>0.01</stddev></noise>
      </ray>
      <plugin name="lidar_plugin" filename="libgazebo_ros_ray_sensor.so">
        <ros><namespace>/</namespace><remapping>~/out:=scan</remapping></ros>
        <output_type>sensor_msgs/LaserScan</output_type>
        <frame_name>lidar_link</frame_name>
      </plugin>
    </sensor>
  </gazebo>

  <!-- ===== IMU ===== -->
  <link name="imu_link">
    <visual><geometry><box size="0.02 0.02 0.01"/></geometry><material name="grey"/></visual>
    <xacro:box_inertial m="0.01" x="0.02" y="0.02" z="0.01"/>
  </link>
  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="imu_link"/>
    <origin xyz="0 0 ${base_height + 0.005}" rpy="0 0 0"/>
  </joint>
  <gazebo reference="imu_link">
    <sensor name="imu_sensor" type="imu">
      <always_on>true</always_on>
      <update_rate>100</update_rate>
      <plugin name="imu_plugin" filename="libgazebo_ros_imu_sensor.so">
        <ros><namespace>/</namespace><remapping>~/out:=imu</remapping></ros>
        <frame_name>imu_link</frame_name>
      </plugin>
    </sensor>
  </gazebo>

  <!-- ===== Camera macro ===== -->
  <xacro:macro name="rgb_camera" params="name xyz rpy topic">
    <link name="${name}_link">
      <visual><geometry><box size="0.03 0.06 0.03"/></geometry><material name="dark"/></visual>
      <xacro:box_inertial m="0.05" x="0.03" y="0.06" z="0.03"/>
    </link>
    <joint name="${name}_joint" type="fixed">
      <parent link="base_link"/>
      <child  link="${name}_link"/>
      <origin xyz="${xyz}" rpy="${rpy}"/>
    </joint>
    <gazebo reference="${name}_link">
      <sensor name="${name}_sensor" type="camera">
        <update_rate>15</update_rate>
        <camera>
          <horizontal_fov>1.3962634</horizontal_fov>
          <image><width>640</width><height>480</height><format>R8G8B8</format></image>
          <clip><near>0.05</near><far>20.0</far></clip>
        </camera>
        <plugin name="${name}_plugin" filename="libgazebo_ros_camera.so">
          <ros><namespace>/</namespace></ros>
          <camera_name>${topic}</camera_name>
          <frame_name>${name}_link</frame_name>
        </plugin>
      </sensor>
    </gazebo>
  </xacro:macro>

  <xacro:rgb_camera name="cam_front" xyz="${base_radius - 0.02} 0 ${base_height}"            rpy="0 0 0"        topic="camera_front"/>
  <xacro:rgb_camera name="cam_rear"  xyz="${-base_radius + 0.02} 0 ${base_height}"           rpy="0 0 ${pi}"    topic="camera_rear"/>
  <xacro:rgb_camera name="cam_left"  xyz="0 ${ base_radius - 0.02} ${base_height}"           rpy="0 0 ${ pi/2}" topic="camera_left"/>
  <xacro:rgb_camera name="cam_right" xyz="0 ${-base_radius + 0.02} ${base_height}"           rpy="0 0 ${-pi/2}" topic="camera_right"/>

  <!-- ===== Depth (RGB-D) camera, front ===== -->
  <link name="depth_cam_link">
    <visual><geometry><box size="0.025 0.10 0.025"/></geometry><material name="grey"/></visual>
    <xacro:box_inertial m="0.05" x="0.025" y="0.10" z="0.025"/>
  </link>
  <joint name="depth_cam_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="depth_cam_link"/>
    <origin xyz="${base_radius - 0.02} 0 ${base_height + 0.04}" rpy="0 0 0"/>
  </joint>
  <gazebo reference="depth_cam_link">
    <sensor name="depth_cam_sensor" type="depth">
      <update_rate>15</update_rate>
      <camera>
        <horizontal_fov>1.047</horizontal_fov>
        <image><width>640</width><height>480</height><format>R8G8B8</format></image>
        <clip><near>0.1</near><far>10.0</far></clip>
      </camera>
      <plugin name="depth_cam_plugin" filename="libgazebo_ros_camera.so">
        <ros><namespace>/</namespace></ros>
        <camera_name>depth_camera</camera_name>
        <frame_name>depth_cam_link</frame_name>
      </plugin>
    </sensor>
  </gazebo>

  <!-- ===== Differential drive plugin ===== -->
  <gazebo>
    <plugin name="diff_drive" filename="libgazebo_ros_diff_drive.so">
      <ros><namespace>/</namespace></ros>
      <update_rate>50</update_rate>
      <left_joint>left_wheel_joint</left_joint>
      <right_joint>right_wheel_joint</right_joint>
      <wheel_separation>${wheel_sep}</wheel_separation>
      <wheel_diameter>${2*wheel_radius}</wheel_diameter>
      <max_wheel_torque>10.0</max_wheel_torque>
      <max_wheel_acceleration>2.0</max_wheel_acceleration>
      <publish_odom>true</publish_odom>
      <publish_odom_tf>true</publish_odom_tf>
      <publish_wheel_tf>true</publish_wheel_tf>
      <odometry_frame>odom</odometry_frame>
      <robot_base_frame>base_footprint</robot_base_frame>
      <command_topic>cmd_vel</command_topic>
    </plugin>
  </gazebo>

  <!-- ===== Joint state publisher plugin ===== -->
  <gazebo>
    <plugin name="joint_states" filename="libgazebo_ros_joint_state_publisher.so">
      <ros><namespace>/</namespace></ros>
      <update_rate>30</update_rate>
      <joint_name>left_wheel_joint</joint_name>
      <joint_name>right_wheel_joint</joint_name>
    </plugin>
  </gazebo>

</robot>
