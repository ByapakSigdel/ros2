# Force LF line endings on checkout for everyone, including Windows clones.
# Without this, Git's core.autocrlf converts shell scripts to CRLF and they
# fail inside Linux containers with errors like: /usr/bin/env: 'bash\r'.
* text=auto eol=lf

*.sh    text eol=lf
*.bash  text eol=lf
*.py    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.xacro text eol=lf
*.urdf  text eol=lf
*.world text eol=lf
*.xml   text eol=lf
Dockerfile  text eol=lf
.gitkeep    text eol=lf

# Binary assets — never touch these
*.png  binary
*.jpg  binary
*.jpeg binary
*.dae  binary
*.stl  binary
*.db3  binary
